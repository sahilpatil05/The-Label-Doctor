# Hugging Face Configuration (Optional - Cloud-based OCR)
# Get your API token from: https://huggingface.co/settings/tokens
# Set to False to use PaddleOCR (recommended for offline/local processing)

HF_API_TOKEN=your_token_here
USE_HUGGINGFACE=False

# Model selection (optional)
# HF_OCR_MODEL=zai-org/GLM-OCR
# HF_ALLERGEN_MODEL=facebook/bart-large-mnli

# API timeout (seconds)
HF_API_TIMEOUT=30

# OCR Engine Priority (Automatic, no configuration needed)
# Priority order:
# 1. PaddleOCR (primary - fast, local, accurate)
# 2. EasyOCR (fallback - multilingual support)
# 3. Hugging Face (cloud-based - requires API token, USE_HUGGINGFACE=True)

# Deployment
FLASK_ENV=production
DEBUG=False
